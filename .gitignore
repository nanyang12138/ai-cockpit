# Python virtual environment
.venv/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Testing
.pytest_cache/
.coverage
htmlcov/

# Type checking
.mypy_cache/

# Ruff
.ruff_cache/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# AI Cockpit history
.ai-cockpit/history/

# AI Cockpit per-run memory suggestions (proposed, not yet accepted).
# These are written by every run and reviewed via `ai-cockpit memory list`
# / `memory show` / `memory accept`. They are runtime artifacts; only
# accepted suggestions land under .ai-cockpit/memory/ and get tracked.
.ai-cockpit/suggestions/

# Aider runtime artifacts (v0.3 step 2 / A.8). These files are written
# by the `aider` CLI itself when `--worker aider --apply` runs; they are
# aider's chat/input history and tag cache, NOT ai-cockpit output. The
# generic `.aider*` glob is the safety net for any future filename aider
# adds. Documented under README "Coder worker (v0.3 step 2)".
.aider.chat.history.md
.aider.input.history
.aider.tags.cache.v4/
.aider*
